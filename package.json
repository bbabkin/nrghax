{
  "name": "supabase-auth-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:https": "node server.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:visual": "playwright test tests/visual-flows",
    "test:visual:update": "playwright test tests/visual-flows --update-snapshots",
    "test:performance": "playwright test tests/performance",
    "test:accessibility": "playwright test tests/visual-flows/auth-flows.visual.spec.ts -g 'Accessibility'",
    "test:all": "npm run test:visual && npm run test:performance",
    "seed:db": "ts-node tests/seed-data/seed-database.ts",
    "seed:clean": "ts-node tests/seed-data/seed-database.ts clean",
    "seed:reset": "ts-node tests/seed-data/seed-database.ts reset",
    "visual:compare": "ts-node tests/visual-flows/screenshot-comparison.ts compare",
    "visual:update-baseline": "ts-node tests/visual-flows/screenshot-comparison.ts update-baseline",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@auth/supabase-adapter": "^1.10.0",
    "@headlessui/react": "^2.1.8",
    "@heroicons/react": "^2.1.5",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/auth-helpers-react": "^0.5.0",
    "@supabase/supabase-js": "^2.45.4",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.445.0",
    "next": "^14.2.32",
    "next-auth": "^5.0.0-beta.29",
    "postcss": "^8.4.47",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.53.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.19.11",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "axe-playwright": "^2.1.0",
    "chrome-launcher": "^1.2.0",
    "dotenv": "^17.2.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lighthouse": "^12.8.2",
    "next-router-mock": "^0.9.13",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.55.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "puppeteer": "^24.17.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5"
  }
}
